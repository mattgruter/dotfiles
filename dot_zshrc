export LANG=en_US.UTF-8

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='vim'
fi

# kubernetes
export KUBECONFIG=$KUBECONFIG:$HOME/.kube/config:$HOME/.kube/config-spotify
alias k="kubectl"

# lsd
alias ls="lsd"

# lazygit
alias lg="lazygit"

# bitwarden
alias bitwarden="bw"
alias bwu='export BW_SESSION=$( bw unlock --raw )'

# homebrew
export PATH=$(brew --prefix)/bin:$PATH
export HOMEBREW_NO_ENV_HINTS=1

# Visual Studio Code
export PATH="$PATH:/Applications/Visual Studio Code.app/Contents/Resources/app/bin"

# gcloud
source "/opt/homebrew/Caskroom/gcloud-cli/latest/google-cloud-sdk/path.zsh.inc"
source "/opt/homebrew/Caskroom/gcloud-cli/latest/google-cloud-sdk/completion.zsh.inc"

# Starship prompt
eval "$(starship init zsh)"

# fix fork issue with ansible (see https://docs.ansible.com/ansible/latest/reference_appendices/faq.html#running-on-macos)
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# include psql & co. in PATH
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"

# custom scripts
export PATH=$PATH:$HOME/bin

# PyEnv
export PYENV_ROOT="$HOME/.pyenv"
command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"
eval "$(pyenv init -)"

